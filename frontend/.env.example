# =============================================================================
# Tribhuban Parent Website — Frontend Environment Variables
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in every value marked with  ← REQUIRED
#   3. Never commit .env.local — it is already in .gitignore
#   4. For Vercel: add each variable in
#      Project → Settings → Environment Variables
#
# =============================================================================


# ── Supabase ──────────────────────────────────────────────────────────────────
#
# Found in: Supabase Dashboard → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL
#   Your project's REST API base URL.
#   Format: https://<project-ref>.supabase.co
#   ← REQUIRED
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# NEXT_PUBLIC_SUPABASE_ANON_KEY
#   The "anon / public" API key — safe to expose in the browser.
#   This key enforces Row Level Security (RLS); it does NOT bypass it.
#   Never use the service_role key on the frontend.
#   ← REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here


# ── Site URL ──────────────────────────────────────────────────────────────────
#
# The canonical public URL of this deployment.
# Used for:
#   - OAuth redirect URL construction
#   - Canonical host enforcement in middleware
#   - Open Graph / SEO metadata
#
# Local dev:   http://localhost:3000
# Production:  https://tribhuban-parent-website.vercel.app  (or custom domain)
#   ← REQUIRED
NEXT_PUBLIC_SITE_URL=https://tribhuban-parent-website.vercel.app


# ── Sentry (optional — error monitoring) ──────────────────────────────────────
#
# Found in: sentry.io → Project → Settings → Client Keys (DSN)
# Leave blank to disable Sentry in this environment.
SENTRY_DSN=

# Found in: sentry.io → Organisation Settings → General → Organisation Slug
SENTRY_ORG=

# Found in: sentry.io → Project → Settings → General → Project Slug
SENTRY_PROJECT=

# Found in: sentry.io → Organisation Settings → Auth Tokens → Create New Token
# Required only for source-map uploads during CI builds.
# Scope needed: project:releases, org:read
SENTRY_AUTH_TOKEN=


# ── API (Backend) ─────────────────────────────────────────────────────────────
#
# Base URL of the FastAPI backend.
# Local dev:   http://localhost:8000
# Production:  https://your-railway-or-render-app.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
