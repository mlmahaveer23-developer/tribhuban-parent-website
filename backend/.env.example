# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tribhuban

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=tribhuban-media
SES_SENDER_EMAIL=noreply@tribhubanconcepts.com

# ── Security ─────────────────────────────────────────────────────────────────
# Must be at least 32 chars; use a cryptographically random value in production
SECRET_KEY=change-me-use-a-real-secret-in-production-abc123
REVALIDATE_SECRET=change-me-revalidation-secret
ADMIN_AUTH_ENABLED=false

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Supabase Auth ─────────────────────────────────────────────────────────────
#
# SUPABASE_JWT_SECRET
#   Used by the backend to verify Supabase-issued JWTs on protected API routes.
#   Found in: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
#   WARNING: This is a server-side secret — never expose it to the frontend.
#   ← REQUIRED in production
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# SUPABASE_PROJECT_URL
#   Your Supabase project's REST API base URL.
#   Found in: Supabase Dashboard → Project Settings → API → Project URL
#   Format: https://<project-ref>.supabase.co
#   ← REQUIRED in production
SUPABASE_PROJECT_URL=https://YOUR_PROJECT_REF.supabase.co
